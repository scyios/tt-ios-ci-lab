# Fastfile for tt-ios-ci-lab (DemoApp)
# 在仓库根目录执行：fastlane ios demo_ci
# 参考文档：Doc/06_fastlane_配置与实战.md

default_platform(:ios)

platform :ios do
  desc "Demo CI：pod install + build_debug + build_archive，导出 IPA + 飞书通知"
  lane :demo_ci do
    # 1. 计算关键路径（仓库根 / DemoApp / ci-scripts）
    repo_root       = File.expand_path("..", __dir__)
    demoapp_path    = File.join(repo_root, "DemoApp")
    build_dir       = File.join(repo_root, "ci-scripts", "build")
    notify_feishu   = File.join(repo_root, "ci-scripts", "notify", "notify_feishu.py")

    begin
      # 2. 安装依赖（与 Jenkins 中一致，使用 RVM 调用 pod）
      Dir.chdir(demoapp_path) do
        sh("export LANG=en_US.UTF-8 LC_ALL=en_US.UTF-8 && /Users/tt/.rvm/bin/rvm 3.4.6 do pod install")
      end

      # 3. Debug 构建（对应 ci-scripts/build/build_debug.sh）
      Dir.chdir(repo_root) do
        sh("chmod +x #{File.join(build_dir, 'build_debug.sh')} && #{File.join(build_dir, 'build_debug.sh')}")
      end

      # 4. Archive + 导出 IPA（对应 ci-scripts/build/build_archive.sh）
      Dir.chdir(repo_root) do
        sh("chmod +x #{File.join(build_dir, 'build_archive.sh')} && #{File.join(build_dir, 'build_archive.sh')}")
      end

      # 5. 构建成功：通知飞书
      sh("python3 #{notify_feishu} --status success --text 'Demo CI 构建成功'")
    rescue => e
      # 6. 构建失败：通知飞书（通知失败不阻塞抛错，用 || true 吃掉自身错误）
      sh("python3 #{notify_feishu} --status failure --text 'Demo CI 构建失败: #{e.message}' || true")
      raise e
    end
  end
end
